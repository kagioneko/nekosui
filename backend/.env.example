# ネコスイ バックエンド 環境変数設定
# このファイルを .env にコピーして、使いたいプロバイダーのキーだけ入力してください。
# 複数入れた場合は上から順に優先されます（Anthropic > OpenAI > Gemini > OpenRouter）。
# ひとつも入れない場合はテンプレートセリフで動作します（LLM不使用）。

# -----------------------------------------------
# どれか1つのAPIキーを入力してください
# -----------------------------------------------

# Anthropic（Claude Haiku）
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI（GPT-4o-mini）
# 取得先: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini（Gemini 2.0 Flash）
# 取得先: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter（複数モデルを1つのAPIで）
# 取得先: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# 使用するモデル（デフォルト: openai/gpt-4o-mini）
# モデル一覧: https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini

# -----------------------------------------------
# 上級設定（通常は変更不要）
# -----------------------------------------------

# プロバイダーを明示的に指定する場合（anthropic / openai / gemini / openrouter）
# 未設定なら入力済みキーから自動判定します
# LLM_PROVIDER=anthropic
